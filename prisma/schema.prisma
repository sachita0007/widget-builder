generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Widget {
  id         String   @id @default(cuid())
  name       String
  template   String
  settings   Json?
  campaignId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
